{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Proprietary owner data including balance and infrastructure state.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "balance": { "type": "number", "description": "Current active BTC yield (Total accumulated)." },
        "internalWalletBalance": { "type": "number", "description": "Rewards strictly collected by the miner e-wallet." },
        "githubConnected": { "type": "boolean", "description": "Whether the user's GitHub account is linked for version control." },
        "cloudflareConnected": { "type": "boolean", "description": "Whether the user's Cloudflare account is linked for edge optimization." },
        "phoneNumber": { "type": "string", "description": "User's mobile device number for SMS notifications." },
        "miningUnits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
               "id": { "type": "string" },
               "typeId": { "type": "string" },
               "name": { "type": "string" },
               "temp": { "type": "number" },
               "fanSpeed": { "type": "number" },
               "status": { "type": "string" },
               "logs": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "multiAssetWallets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "coin": { "type": "string" },
              "address": { "type": "string" },
              "app": { "type": "string" },
              "label": { "type": "string" },
              "balance": { "type": "number" },
              "minerActive": { "type": "boolean" },
              "hashRate": { "type": "number" },
              "progress": { "type": "number" },
              "isVerified": { "type": "boolean" },
              "lastTxHash": { "type": "string" },
              "confirmations": { "type": "number" }
            }
          }
        },
        "lastSync": { "type": "string", "format": "date-time" },
        "ownerTreasury": { "type": "number", "description": "Protocol cut treasury." },
        "walletAddress": { "type": "string" },
        "payoutEmail": { "type": "string" },
        "isAiAutonomous": { "type": "boolean" },
        "isAjiPro": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "autoReinvest": { "type": "boolean" },
        "protocolLevel": { "type": "number" },
        "settlementBatches": {
          "type": "array",
          "items": { "type": "object" },
          "description": "History of fiat off-ramp settlements."
        },
        "transactions": {
          "type": "array",
          "items": { "type": "object" },
          "description": "History of BTC on-chain transactions."
        },
        "hwState": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "health": { "type": "number" },
              "count": { "type": "number" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "balance", "updatedAt"]
    },
    "Log": {
       "title": "Mining Log",
       "description": "Event log for the mining cluster.",
       "type": "object",
       "properties": {
         "time": { "type": "string" },
         "msg": { "type": "string" },
         "type": { "type": "string", "enum": ["success", "alert", "info", "network", "system"] },
         "hashRate": { "type": "string" }
       }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root user profile document."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "Log",
      "description": "Individual event logs for history."
    }
  }
}

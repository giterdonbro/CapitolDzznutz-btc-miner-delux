rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        request.resource.data.email == resource.data.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'internalWalletBalance', 'updatedAt', 'lastSync', 'hwState', 'ownerTreasury', 'autoReinvest', 'protocolLevel', 'isAiAutonomous'])
      );

      match /logs/{logId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLog(request.resource.data);
      }
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'balance', 'updatedAt']) &&
             data.email is string &&
             data.balance is number &&
             (data.keys().hasAny(['internalWalletBalance']) ? data.internalWalletBalance is number : true) &&
             data.updatedAt == request.time;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['time', 'msg', 'type']) &&
             data.msg.size() <= 500;
    }
  }
}
